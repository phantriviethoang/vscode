{
    "editor.guides.indentation": false,
    "editor.cursorBlinking": "blink",
    "vim.cursorStylePerMode.insert": "block",
    "scm.diffDecorations": "none",
    "editor.colorDecorators": true,
    "editor.occurrencesHighlight": "off",
    "editor.renderLineHighlight": "none",
    "editor.matchBrackets": "never",
    "editor.lightbulb.enabled": "off",
    "editor.scrollbar.vertical": "hidden",
    "editor.fontLigatures": true,
    "editor.rulers": [
        {
            "column": 0,
            "color": "#161e28"
        }
    ],
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "vendor/": true,
        "resources/views/vendor/**": false,
        "resources/js/actions/**": true,
        "resources/js/routes/**": true,
        "resources/js/wayfinder/**": true,
        "**/dist": true,
        "**/_ide_helper.php": true,
        "**/composer.lock": true,
        "**/package-lock.json": true,
        "storage/framework/views": true,
        ".phpunit.result.cache": true
    },
    "files.exclude": {
        "**/.git": true,
        "**/.github": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true,
        "**/storage": true,
        "**/bootstrap/cache": true,
        "**/.env": true,
        "**/.env.*": true,
        "**/tests": true,
        "**/.editorconfig": true,
        "**/artisan": true,
        "**/components.json": true,
        "**/composer.json": true,
        "**/composer.lock": true,
        "**/phpunit.xml": true,
        "**/.eslintrc.json": true,
        "**/.gitignore": true,
        "**/.gitattributes": true,
        "**/.vscode": true,
        "**/.prettierrc": true,
        "**/.prettierignore": true,
        "**/vite.config.*": true,
        "**/jsconfig.json": true,
        "**/tsconfig.json": true,
        "**/next.config.*": true,
        "**/next-env.d.ts": true,
        "**/tailwind.config.js": true,
        "**/package.json": true,
        "**/package-lock.json": true,
        "**/pint.json": true,
        "**/yarn.lock": true,
        "**/pnpm-lock.yaml": true,
        "**/.npmrc": true,
        "**/bun.lockb": true,
        "**/eslint.config.*": true,
        "**/postcss.config.*": true,
        "**/README.md": true,
        "**/dist": true,
        "**/build": true,
        "**/.idea": true,
        "**/.next": true
    }
}
