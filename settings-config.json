{
	//  test

	"editor.fontFamily": "Dank Mono",
	"editor.fontSize": 17,
	"terminal.integrated.fontFamily": "Dank Mono",
	"scm.inputFontFamily": "Dank Mono",
	"terminal.integrated.fontSize": 17,
	"terminal.integrated.lineHeight": 1.3,
	"editor.rulers": [
		{
			"color": "#1c2430"
		}
	],
	"workbench.colorCustomizations": {
		"sideBar.border": "#1c2430",
		"terminal.tab.activeBorder": "#1c2430",
		"terminal.border": "#1c2430",
		"panel.border": "#1c2430",
		"editorGutter.deletedBackground": "#757575",
		"titleBar.activeForeground": "#5D6976",
		"titleBar.inactiveForeground": "#5D6976"
	},
	"workbench.colorTheme": "Carbon",

	"search.exclude": {
		".next/**": true,
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true,
		"vendor/": true,
		"resources/views/vendor/**": false,
		"resources/js/actions/**": true,
		"resources/js/routes/**": true,
		"resources/js/wayfinder/**": true,
		"**/dist": true,
		"**/_ide_helper.php": true,
		"**/composer.lock": true,
		"**/package-lock.json": true,
		"storage/framework/views": true,
		".phpunit.result.cache": true
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},

	"files.exclude": {
		"**/.git": true,
		"**/.github": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/node_modules": true,
		"**/public": true,
		"**/assets": true,
		"**/storage": true,
		"**/bootstrap/cache": true,
		"**/.env": true,
		"**/.env.*": true,
		"**/tests": true,
		"**/.editorconfig": true,
		"**/artisan": true,
		"**/components.json": true,
		"**/composer.json": true,
		"**/composer.lock": true,
		"**/phpunit.xml": true,
		"**/.eslintrc.json": true,
		"**/.gitignore": true,
		"**/.gitattributes": true,
		"**/.vscode": true,
		"**/.prettierrc": true,
		"**/.prettierignore": true,
		"**/vite.config.*": true,
		"**/jsconfig.json": true,
		"**/tsconfig.json": true,
		"**/next.config.*": true,
		"**/next-env.d.ts": true,
		"**/tailwind.config.js": true,
		"**/package.json": true,
		"**/package-lock.json": true,
		"**/pint.json": true,
		"**/yarn.lock": true,
		"**/.npmrc": true,
		"**/pnpm-lock.yaml": true,
		"**/bun.lockb": true,
		"**/eslint.config.*": true,
		"**/postcss.config.*": true,
		"**/AGENTS.md": true,
		"**/CLAUDE.md": true,
		"**/README.md": true,
		"**/dist": true,
		"**/build": true,
		"**/.idea": true,
		"**/.next": true
	}

	// test
}
